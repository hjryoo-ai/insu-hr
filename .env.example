# .env.example — InsuHR 환경변수 (프로덕션 주입용 목록). 실제 .env는 커밋 금지(.gitignore).
#
# 아래 값은 전부 더미다. 프로덕션에서는 KMS/Vault로 실제 값을 주입한다(설계서 §10.3).
# 로컬 개발은 domain의 crypto-common.yml / jpa-common.yml에 든 'local-dev-only' 기본값이
# 커버하므로 .env 없이도 뜬다 — 이 파일은 "무엇을 주입해야 하는가"의 목록이다.

# ── DB (Oracle 23ai) ──
INSUHR_DB_URL=jdbc:oracle:thin:@localhost:1521/FREEPDB1
INSUHR_DB_USER=insuhr
INSUHR_DB_PASSWORD=change-me

# ── 필드 암호화 (AES-256-GCM, 키 버전 프리픽스) ──
# 32바이트 키를 base64로. 생성 예: openssl rand -base64 32
INSUHR_AES_CURRENT_KEY_VERSION=v1
INSUHR_AES_KEY_V1=REPLACE_WITH_BASE64_32BYTE_KEY
# 주민번호 해시용 pepper (충분히 긴 랜덤). 생성 예: openssl rand -base64 32
INSUHR_RRN_PEPPER=REPLACE_WITH_RANDOM_PEPPER

# ── JWT (HS256) ──
# 서명 시크릿 (충분히 긴 랜덤). 생성 예: openssl rand -base64 48
INSUHR_JWT_SECRET=REPLACE_WITH_RANDOM_JWT_SECRET

# ── Kafka (relay의 kafka 프로파일에서만) ──
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# 참고: 데모 계정(demo/seed.sql)의 비밀번호 'demo1234!'는 데모 전용이며 로컬에서만 쓴다.
